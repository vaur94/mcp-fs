{
  "mcpServers": {
    "mcp-fs": {
      "type": "stdio",
      "command": "/home/you/.local/bin/mcp-fs",
      "args": [
        "--config",
        "/home/you/Projects/mcp-fs/samples/mcp-fs.config.json.sample"
      ],
      "env": {
        "MCP_FS_ROOT": "/home/you/Projects"
      }
    },
    "mcp-fs-source": {
      "type": "stdio",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "/home/you/Projects/mcp-fs/src/McpFs/McpFs.csproj",
        "-c",
        "Release",
        "--",
        "--config",
        "/home/you/Projects/mcp-fs/samples/mcp-fs.config.json.sample"
      ],
      "env": {
        "MCP_FS_ROOT": "/home/you/Projects"
      },
      "enabled": false
    }
  }
}
